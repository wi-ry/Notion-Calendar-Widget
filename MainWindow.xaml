<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="NotionCalendarWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notion Calendar Widget"
        Width="800"
        Height="600"
        WindowStartupLocation="CenterScreen"
        Background="White">
    <Grid>
        <DockPanel LastChildFill="True">
            <!-- Title Bar -->
            <StackPanel DockPanel.Dock="Top" Height="40" Orientation="Horizontal" Background="#F3F3F3" Padding="12,8">
                <TextBlock Text="Notion Calendar" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
            
            <!-- WebView2 Container (will be added programmatically) -->
            <Border x:Name="WebViewContainer" Background="White" />
            
            <!-- Status Bar -->
            <StackPanel DockPanel.Dock="Bottom" Height="30" Background="#F3F3F3" Orientation="Horizontal" Padding="12,0">
                <TextBlock x:Name="StatusText" Text="Loading..." FontSize="12" VerticalAlignment="Center" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
