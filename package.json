{
  "name": "notion-calendar-widget",
  "version": "1.3.0",
  "description": "Notion Calendar desktop widget",
  "author": "Will Ryan <will@willryan.ca>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check main.js && node --check preload.js && node --check renderer.js && node --check options-preload.js && node --check optionsRenderer.js",
    "lint:commits": "commitlint --from HEAD~20 --to HEAD --verbose",
    "build:win": "electron-builder --win --x64 --publish never",
    "release": "semantic-release",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.1",
    "@commitlint/config-conventional": "^19.4.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "electron": "latest",
    "electron-builder": "^26.15.3",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.5"
  },
  "build": {
    "appId": "ca.willryan.notioncalendarwidget",
    "productName": "Notion Calendar Widget",
    "files": [
      "*.js",
      "*.html",
      "package.json",
      "assets/**"
    ],
    "directories": {
      "output": "release"
    },
    "icon": "assets/notion-calendar.ico",
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-Setup-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable-${arch}.${ext}"
    }
  }
}
